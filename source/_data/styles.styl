// Dark, minimal technical finish for NexT.
:root {
  --body-bg-color: #080b10;
  --content-bg-color: #0d1117;
  --card-bg-color: #0f141c;
  --text-color: #d6deeb;
  --link-color: #5eead4;
  --link-hover-color: #93c5fd;
  --brand-color: #5eead4;
  --brand-hover-color: #93c5fd;
  --btn-default-bg: #121826;
  --btn-default-color: #d6deeb;
  --btn-default-border-color: #263244;
  --highlight-background: #0b1020;
  --highlight-foreground: #d6deeb;
}

body {
  background:
    linear-gradient(180deg, rgba(16, 24, 39, .92), rgba(8, 11, 16, 1) 360px),
    radial-gradient(circle at 12% 0%, rgba(94, 234, 212, .08), transparent 340px);
  color: var(--text-color);
}

.header-inner,
.sidebar-inner,
.post-block,
.comments,
.pagination {
  background: rgba(13, 17, 23, .86);
  border: 1px solid rgba(148, 163, 184, .14);
  box-shadow: 0 18px 50px rgba(0, 0, 0, .28);
}

.site-brand-container {
  background: linear-gradient(135deg, #0f172a, #111827);
}

.site-title {
  letter-spacing: 0;
  font-weight: 700;
}

.site-subtitle {
  color: #8ea7bd;
}

.menu-item a,
.sidebar a,
.post-meta,
.post-copyright {
  color: #93a4b7;
}

.menu-item-active a,
.menu-item a:hover,
.post-title a:hover,
.sidebar a:hover {
  color: #5eead4;
}

.post-title {
  font-weight: 700;
  letter-spacing: 0;
}

.post-body {
  color: #d6deeb;
  line-height: 1.82;
}

.post-body h2,
.post-body h3,
.post-body h4 {
  border-bottom-color: rgba(148, 163, 184, .18);
}

.post-body code {
  background: #121826;
  border: 1px solid rgba(148, 163, 184, .16);
  color: #f8fafc;
}

.post-body pre,
.highlight {
  border: 1px solid rgba(148, 163, 184, .14);
  border-radius: 8px;
}

.post-body img {
  border: 1px solid rgba(148, 163, 184, .18);
  border-radius: 8px;
  background: #0b1020;
}

.btn,
.page-number,
.extend {
  border-radius: 6px;
}

.search-popup {
  background: #0d1117;
  border: 1px solid rgba(148, 163, 184, .18);
}

.search-input-container input {
  background: #080b10;
  color: #d6deeb;
}
